# ── GitHub ──────────────────────────────────────────────────────────────────
# In GitHub Actions, GITHUB_TOKEN is set automatically.
# For local testing, generate a fine-grained PAT with:
#   - Contents: Read & Write
#   - Pull requests: Read & Write
GITHUB_TOKEN=ghp_your_token_here

# ── LLM provider ────────────────────────────────────────────────────────────
# Supported: anthropic | openai | google-genai
LLM_PROVIDER=anthropic

# Model name for the chosen provider
LLM_MODEL=claude-sonnet-4-6
# LLM_MODEL=gpt-4.1
# LLM_MODEL=gemini-2.5-pro

# ── API keys — set only the one that matches LLM_PROVIDER ───────────────────
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# ── PR context — set automatically in Actions; fill in for local testing ─────
PR_NUMBER=1
REPO_OWNER=your-github-username
REPO_NAME=your-target-repo
PR_HEAD_BRANCH=feature/my-branch
PR_BASE_BRANCH=main
